<% layout("layouts/boilerplate.ejs") %>
  <h3 class=" index-p pt-3 fs-4  ">Popular homes <i class="fa fa-terminal" aria-hidden="true"></i></h3>
  <div class="container-fluid mt-4 px-5">
    <div class="listing-grid">
      <% for(let listing of allListings) { %>
        <div class="col">
          <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card h-100">
              <img src="<%= listing.image %>" class="card-img-top " alt="listingImage">
              <div class="card-img-overlay"></div>
              <div class="card-body d-flex flex-column">
                <h5 class="card-title">
                  <%= listing.title %>
                </h5>
                <p class="card-price mt-auto">
                  ₹<%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %> for 2 Nights
                </p>
              </div>
            </div>
          </a>
        </div>
        <% } %>
    </div>
  </div>