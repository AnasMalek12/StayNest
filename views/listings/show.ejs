<% layout("layouts/boilerplate") %>
<div class="row">
  <div class="col-12 col-md-8 col-lg-6 mx-auto">
    <h3 class="mt-3"><%=listing.title%></h3>
    <div class="mt-3">
      <div class="card h-100">
        <img
          src="<%= listing.image%>"
          class="card-img-show"
          alt="listingImage"
        />
        <div class="card-img-overlay"></div>

        <div class="card-body d-flex flex-column">
          <p class="card-text mt-1 mb-0">Hosted By : <b><%= listing.owner.username.toUpperCase() %></b> @<%= listing.title %></p> <hr>
          <p class="card-text"><%= listing.description %></p>
          <p class="card-price mt-auto">
            ₹<%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %>
            for 2 Nights
          </p>
          <p class="card-text">
            <strong>Location:</strong> <%= listing.location %>, <%=
            listing.country %>
          </p>
        </div>
      </div>
    </div>
    <% if(currUser && listing.owner._id.equals(currUser._id)){ %>
    <div class="show-btn d-flex gap-2 mt-2">
      <a
        href="/listings/<%= listing._id %>/edit"
        class="btn btn-outline-primary"
      >
        Edit
      </a>

      <form class="delete-form" method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-outline-danger">Delete</button>
      </form>
    </div>
    <% } %>

    
    <div class="col-8 mt-4">
      <% if(currUser) { %>
      <h4>Leave A Review :</h4>

      <form
        action="/listings/<%= listing._id %>/reviews"
        method="POST"
        class="needs-validation"
        novalidate
      >
        <div class="mb-3">
          <label for="rating" class="form-label">Rating :</label>
          <input
            type="range"
            min="0"
            max="5"
            step="1"
            id="rating"
            name="review[rating]"
            class="form-range"
          />
        </div>
       

        <div class="mt-2 mb-3">
          <label for="comment" class="form-label">Comment :</label>
          <textarea
            name="review[comment]"
            id="comment"
            cols="30"
            rows="5"
            class="form-control"
            required
          ></textarea>
          <div class="invalid-feedback">
            Provide a valuable feedback comment
          </div>
        </div>

        <button class="btn btn-outline-dark">Submit Review</button>
        <% } %>
      </form>
    </div>
    <hr class="my-5" />

<h3 class="mb-4">🙋🏻‍♂️ Guest Reviews :</h3>

<div class="row">
  <% for(let review of listing.reviews){ %>
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm border-0 h-100 review-card">
        <div class="card-body">
          <div class="d-flex  align-items-center mb-2">
           <div class="review-user">
            <div class="avatar">
              <%= review.author.username.charAt(0).toUpperCase() %>
            </div>
          </div>
          <h5 class="card-title ms-2 mt-2 text-dark">@<%= review.author.username.toUpperCase() %></h5>
            <span class="badge bg-secondary text-light ms-auto">
              ⭐ <%= review.rating %>/5
            </span>
          </div>
          <p class="card-text">
            <%= review.comment %>
          </p>
          <div class="mrg">
          <small class="text-muted" >
          Posted recently
        </small>
        <% if(currUser && review.author._id.equals(currUser._id)){ %>
        <form class="btn-dlt"
              action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
              method="POST"
            >
              <button
                class="btn btn-sm btn-outline-danger rounded-pill"
              >
                ⛌
              </button>
            </form>
            <% } %>
        </div>
        </div>
      </div>
    </div>
  <% } %>
</div>
  </div>
</div>
