<% layout("layouts/boilerplate.ejs") %>
<div class="row">
  <div class="col-8">
    <h3 class="mt-3">Create A New Listing :</h3>
    <form
      id="listing-form-create"
      method="POST"
      action="/listings"
      class="needs-validation"
      novalidate
    >
      <div class="mt-3">
        <label for="listing[title]" class="form-label">Title</label>
        <input
          name="listing[title]"
          placeholder="Enter Title"
          type="text"
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a valid title</div>
      </div>

      <div class="mt-3">
        <label for="listing[description]" class="form-label">Description</label>
        <textarea
          name="listing[description]"
          placeholder="Enter Description"
          class="form-control"
          required
        ></textarea>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a valid description</div>
      </div>

      <div class="mt-3">
        <label for="listing[image]">Image</label>
        <input
          name="listing[image]"
          placeholder="Enter Image URL/Link"
          type="text"
          class="form-control"
          required
        />

        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a valid URL</div>
      </div>
      <div class="row">
        <div class="mt-3 col-md-4">
          <label for="listing[price]" class="form-label">Price</label>
          <input
            name="listing[price]"
            placeholder="Enter Price"
            type="number"
            class="form-control"
            required
          />
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Please enter a valid price</div>
        </div>
        <div class="mt-3 col-md-8">
          <label for="listing[location]" class="form-label">Location</label>
          <input
            name="listing[location]"
            placeholder="Enter Location"
            type="text"
            class="form-control"
            required
          />
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Please enter a valid location</div>
        </div>
      </div>

      <div class="mt-3">
        <label for="listing[country]" class="form-label">Country</label>
        <input
          name="listing[country]"
          placeholder="Enter Country"
          type="text"
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a valid country</div>
      </div>

      <button type="submit" class="btn btn-outline-danger mt-4">Add</button>
    </form>
  </div>
</div>
